<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" monitorInterval="30">

    <Properties>
        <Property name="STANDARD_PATTERN">%d{ISO8601} %-5level [%t] [%c{1}] - %msg%n</Property>
        <Property name="USER_PATTERN">%d{yyyy-MM-dd HH:mm:ss} %-5level - %msg%n</Property>
        <Property name="WRIMS_LOG_DIR">${sys:user.home}/.wrims/logs</Property>
        <Property name="WRIMS_FALLBACK_LOG_DIR">${sys:user.home}/.wrims/logs/runs</Property>
        <Property name="DETAILED_PATTERN">%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n</Property>
        <Property name="SOLVER_LOG_DIR">${WRIMS_LOG_DIR}/solver-logs</Property>
    </Properties>

    <Appenders>
        <Console name="CONSOLE" target="SYSTEM_OUT" follow="true">
            <PatternLayout pattern="${USER_PATTERN}"/>
        </Console>

        <Async name="CONSOLE-ASYNC">
            <AppenderRef ref="CONSOLE"/>
        </Async>

        <File name="FILE" fileName="${sys:project.dir:-${WRIMS_FALLBACK_LOG_DIR}}/${date:yyyy-MM-dd_HH-mm-ss}.log">
            <PatternLayout pattern="${STANDARD_PATTERN}"/>
        </File>

        <Async name="FILE-ASYNC">
            <AppenderRef ref="FILE"/>
        </Async>

        <RollingFile name="FILE-WRIMS"
                     fileName="${WRIMS_LOG_DIR}/wrims-engine.log"
                     filePattern="${WRIMS_LOG_DIR}/wrims-engine-%d{yyyy-MM-dd}.log"
                     append="true">
            <PatternLayout pattern="${STANDARD_PATTERN}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>

        <Async name="FILE-WRIMS-ASYNC">
            <AppenderRef ref="FILE-WRIMS"/>
        </Async>

        <RollingFile name="CBC"
                     fileName="${SOLVER_LOG_DIR}/cbc.log"
                     filePattern="${SOLVER_LOG_DIR}/cbc-%d{yyyy-MM-dd_HH-mm-ss}.log"
                     createOnDemand="true">
            <PatternLayout pattern="${DETAILED_PATTERN}"/>
            <Policies>
                <OnStartupTriggeringPolicy/>
                <SizeBasedTriggeringPolicy size="50 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>

        <Async name="ASYNC-CBC">
            <AppenderRef ref="CBC"/>
        </Async>

        <RollingFile name="XA"
                     fileName="${SOLVER_LOG_DIR}/xa.log"
                     filePattern="${SOLVER_LOG_DIR}/xa-%d{yyyy-MM-dd_HH-mm-ss}.log"
                     createOnDemand="true">
            <PatternLayout pattern="${DETAILED_PATTERN}"/>
            <Policies>
                <OnStartupTriggeringPolicy/>
                <SizeBasedTriggeringPolicy size="50 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>

        <Async name="ASYNC-XA">
            <AppenderRef ref="XA"/>
        </Async>

        <RollingFile name="CBC-SOLVER-PERF"
                     fileName="${SOLVER_LOG_DIR}/cbc-solver-perf.log"
                     filePattern="${SOLVER_LOG_DIR}/cbc-solver-perf-%d{yyyy-MM-dd_HH-mm-ss}.log"
                     createOnDemand="true">
            <PatternLayout pattern="${STANDARD_PATTERN}"/>
            <Policies>
                <OnStartupTriggeringPolicy/>
                <SizeBasedTriggeringPolicy size="50 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="100"/>
        </RollingFile>

        <Async name="ASYNC-CBC-SOLVER-PERF">
            <AppenderRef ref="CBC-SOLVER-PERF"/>
        </Async>

        <RollingFile name="XA-SOLVER-PERF"
                     fileName="${SOLVER_LOG_DIR}/xa-solver-perf.log"
                     filePattern="${SOLVER_LOG_DIR}/xa-solver-perf-%d{yyyy-MM-dd_HH-mm-ss}.log"
                     createOnDemand="true">
            <PatternLayout pattern="${STANDARD_PATTERN}"/>
            <Policies>
                <OnStartupTriggeringPolicy/>
                <SizeBasedTriggeringPolicy size="50 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="100"/>
        </RollingFile>

        <Async name="ASYNC-XA-SOLVER-PERF">
            <AppenderRef ref="XA-SOLVER-PERF"/>
        </Async>

        <RollingFile name="UNKNOWN-SOLVER-PERF"
                     fileName="${SOLVER_LOG_DIR}/unknown-solver-perf.log"
                     filePattern="${SOLVER_LOG_DIR}/unknown-solver-perf-%d{yyyy-MM-dd_HH-mm-ss}.log"
                     createOnDemand="true">
            <PatternLayout pattern="${STANDARD_PATTERN}"/>
            <Policies>
                <OnStartupTriggeringPolicy/>
                <SizeBasedTriggeringPolicy size="20 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="20"/>
        </RollingFile>

        <Async name="ASYNC-UNKNOWN-SOLVER-PERF">
            <AppenderRef ref="UNKNOWN-SOLVER-PERF"/>
        </Async>
    </Appenders>

    <Loggers>
        <Root level="DEBUG">
            <AppenderRef ref="FILE-WRIMS-ASYNC"/>
        </Root>

        <Logger name="gov.ca.water.wrims.engine.core" level="INFO" additivity="true">
            <AppenderRef ref="CONSOLE-ASYNC"/>
            <AppenderRef ref="FILE-ASYNC"/>
        </Logger>

        <Logger name="gov.ca.water.wrims.engine.core.solver.CbcSolver" level="DEBUG" additivity="false">
            <AppenderRef ref="ASYNC-CBC"/>
        </Logger>

        <Logger name="gov.ca.water.wrims.engine.core.solver.xa.main" level="INFO" additivity="false">
            <AppenderRef ref="ASYNC-XA"/>
        </Logger>

        <Logger name="gov.ca.water.wrims.engine.core.solver.xa" level="INFO" additivity="false">
            <AppenderRef ref="ASYNC-XA"/>
        </Logger>

        <Logger name="gov.ca.water.wrims.engine.core.solver.XASolver" level="INFO" additivity="false">
            <AppenderRef ref="ASYNC-XA"/>
        </Logger>

        <Logger name="gov.ca.water.wrims.engine.core.solver.perf.cbc" level="DEBUG" additivity="false">
            <AppenderRef ref="ASYNC-CBC-SOLVER-PERF"/>
        </Logger>

        <Logger name="gov.ca.water.wrims.engine.core.solver.perf.xa" level="DEBUG" additivity="false">
            <AppenderRef ref="ASYNC-XA-SOLVER-PERF"/>
        </Logger>

        <Logger name="gov.ca.water.wrims.engine.core.solver.perf.unknown" level="DEBUG" additivity="false">
            <AppenderRef ref="ASYNC-UNKNOWN-SOLVER-PERF"/>
        </Logger>
    </Loggers>
</Configuration>